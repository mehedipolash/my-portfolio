# ---- MongoDB Atlas ----
# Connection string from Atlas (Database > Connect > Drivers).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=portfolio

# ---- Admin auth (single user: you) ----
ADMIN_EMAIL=you@example.com
# Generate with: node scripts/hash-password.mjs "your-password"
ADMIN_PASSWORD_HASH=$2a$12$replace_with_generated_hash
# Long random string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_long_random_string

# ---- Credly badge sync ----
# Vanity slug from https://www.credly.com/users/<this-part>
CREDLY_USERNAME=md-mehedi-hasan-polash
# Optional: protects manual /api/sync-badges calls (Vercel Cron is auto-trusted).
CRON_SECRET=replace_with_random_string
